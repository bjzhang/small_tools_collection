# feishu-opencode-bot 环境变量模板
#
# 用法：
#   1. cp .env.example .env
#   2. 填入真实凭据（.env 已 gitignore，不会入仓）
#   3. ./run.sh  # 自动 source .env
#
# 字段说明：
#   - FEISHU_APP_ID/SECRET: 从 https://open.feishu.cn/app 获取（飞书企业自建应用）
#   - OPENCODE_*: opencode serve 实例（启动时用相同环境变量名）
#   - FEISHU_WHITELIST_USER_IDS: 逗号分隔的飞书 user open_id（仅作记录，实际白名单在 config.yaml）

# 飞书应用凭据
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# opencode serve HTTP API 后端
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
# 与 opencode 官方约定一致（启动 opencode serve 时也用这个名字）
OPENCODE_SERVER_PASSWORD=your-strong-password-here

# 飞书用户白名单（逗号分隔多个 user open_id）
# 注意：实际生效的白名单在 config.yaml 的 security.allowed_users（YAML list）
# 这里仅作为参考记录
FEISHU_WHITELIST_USER_IDS=ou_xxxxxxxxxxxxxxxx